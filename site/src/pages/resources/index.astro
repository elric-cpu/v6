---
import { company, resources } from "@benson/shared";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title={`Resources | ${company.brandName}`} description="Practical repair and maintenance resources for Harney County properties.">
  <section class="band">
    <h1>Resources</h1>
    <div class="grid">
      {resources.map((resource) => (
        <article class="card">
          <h2>{resource.title}</h2>
          <p>{resource.description}</p>
          <a class="button button--secondary" href={`/resources/${resource.slug}`}>Read Resource</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
