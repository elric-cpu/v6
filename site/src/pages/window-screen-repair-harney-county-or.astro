---
import { company } from "@benson/shared";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title={`Window Screen Repair Harney County OR | ${company.brandName}`} description="Window screen repair and replacement intake for Harney County properties.">
  <section class="band">
    <h1>Window Screen Repair in Harney County</h1>
    <p class="lede">Send opening counts, dimensions where available, photos, the address or location, access notes, and timing constraints for route review.</p>
    <a class="button" href="/contact">Request Review</a>
  </section>
</BaseLayout>
