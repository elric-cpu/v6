---
import { company } from "@benson/shared";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" />
    <style is:global>
      :root {
        color-scheme: light;
        --maroon: #722f37;
        --maroon-dark: #5c252c;
        --burgundy: #8b454d;
        --wine: #4a1f24;
        --cream: #f5f1e8;
        --offwhite: #faf8f3;
        --charcoal: #2d2d2d;
        --slate: #4a4a4a;
        --pale: #e5e5e5;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--offwhite);
        color: var(--charcoal);
        font-family: Arial, Helvetica, sans-serif;
        line-height: 1.55;
      }

      a {
        color: var(--maroon);
      }

      .site-header,
      .site-footer {
        background: var(--wine);
        color: var(--offwhite);
      }

      .site-header__inner,
      .site-footer__inner,
      main > section {
        width: min(1120px, calc(100% - 32px));
        margin: 0 auto;
      }

      .site-header__inner {
        display: flex;
        min-height: 72px;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
      }

      .brand {
        color: var(--offwhite);
        font-size: 1.05rem;
        font-weight: 700;
        text-decoration: none;
      }

      .nav {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
      }

      .nav a,
      .site-footer a {
        color: var(--offwhite);
        text-decoration: none;
      }

      .hero {
        display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.8fr);
        gap: 40px;
        align-items: center;
        padding: 64px 0;
      }

      .band {
        padding: 56px 0;
      }

      .band--cream {
        background: var(--cream);
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
        gap: 20px;
      }

      .card {
        min-height: 100%;
        border: 1px solid var(--pale);
        border-radius: 8px;
        background: var(--offwhite);
        padding: 22px;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        border-radius: 8px;
        background: var(--maroon);
        color: var(--offwhite);
        padding: 10px 16px;
        text-decoration: none;
        font-weight: 700;
      }

      .button--secondary {
        border: 1px solid var(--maroon);
        background: transparent;
        color: var(--maroon);
      }

      .hero img,
      .media img {
        display: block;
        width: 100%;
        height: auto;
        border-radius: 8px;
      }

      h1,
      h2,
      h3 {
        line-height: 1.15;
      }

      h1 {
        font-size: clamp(2.3rem, 6vw, 4.7rem);
        margin: 0 0 20px;
      }

      h2 {
        font-size: 2rem;
        margin: 0 0 18px;
      }

      .lede {
        color: var(--slate);
        font-size: 1.15rem;
        max-width: 760px;
      }

      .site-footer__inner {
        display: grid;
        gap: 8px;
        padding: 32px 0;
      }

      @media (max-width: 760px) {
        .site-header__inner,
        .hero {
          grid-template-columns: 1fr;
        }

        .site-header__inner {
          align-items: flex-start;
          flex-direction: column;
          padding: 16px 0;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="brand" href="/">{company.brandName}</a>
        <nav class="nav" aria-label="Primary">
          <a href="/services">Services</a>
          <a href="/areas">Areas</a>
          <a href="/plans">Plans</a>
          <a href="/resources">Resources</a>
          <a href="/contact">Contact</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-footer__inner">
        <strong>{company.legalName}</strong>
        <span>Oregon CCB {company.oregonCcb} | {company.phone} | {company.email}</span>
      </div>
    </footer>
  </body>
</html>
