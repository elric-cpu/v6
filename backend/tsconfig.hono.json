{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "skipLibCheck": true,
    "types": ["node"],
    "outDir": "dist-hono"
  },
  "include": ["src-hono/**/*.ts", "test-hono/**/*.ts"]
}
